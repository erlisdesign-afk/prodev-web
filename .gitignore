# ProDev OS — .gitignore

# Outputs generados (no versionar drafts locales)
outputs/**/*.md
outputs/**/*.pdf
outputs/**/*.pptx
outputs/**/*.docx
!outputs/**/.gitkeep

# Contexto privado / sensible
context/secrets.md
context/financials-private.md

# Brand assets generados localmente
brand/brand.json
brand/config.json

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Variables de entorno
.env
.env.local
.env*.local

# Node / Python (si se agregan scripts de automatización)
node_modules/
__pycache__/
*.pyc
.venv/
dist/
build/

# Logs
*.log
logs/

# Claude cache
.claude/cache/
